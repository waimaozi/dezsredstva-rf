---
import Layout from "../layouts/Layout.astro";

const sections = [
  {
    href: "/products/",
    title: "Каталог дезсредств",
    text: "Карточки средств Химитек с назначением, рабочими концентрациями и сферами применения."
  },
  {
    href: "/tools/",
    title: "Калькуляторы",
    text: "Расчёт разведения растворов и подготовка режимов обработки для ежедневной работы."
  },
  {
    href: "/compare/",
    title: "Сравнение групп",
    text: "Сводные таблицы по хлорным, ЧАС, перекисным и спиртовым составам."
  },
  {
    href: "/research/",
    title: "Дайджест исследований",
    text: "Подборки материалов по эффективности, устойчивости и практике дезинфекции."
  },
  {
    href: "/regulations/",
    title: "Нормативные документы",
    text: "СанПиН, ГОСТ, методические указания и краткие пояснения по применению."
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Дезинфицирующиесредства.рф",
  url: "https://дезинфицирующиесредства.рф/",
  inLanguage: "ru",
  description: "Информационный агрегатор по дезинфицирующим средствам, нормативам и инструментам расчёта."
};
---

<Layout
  title="Дезинфицирующиесредства.рф — каталог дезсредств, нормативы и инструменты"
  description="Профессиональный агрегатор по дезинфицирующим средствам: каталог, сравнение активных веществ, калькулятор разведения и нормативные документы."
  pathname="/"
  structuredData={structuredData}
>
  <section class="grid gap-8 lg:grid-cols-[1.2fr_0.8fr]">
    <div class="section-shell overflow-hidden p-8 sm:p-10">
      <span class="eyebrow">Профессиональная дезинфекция</span>
      <h1 class="mt-5 max-w-3xl text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
        Каталог дезинфицирующих средств и практические материалы для выбора режима обработки
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">
        Дезинфицирующиесредства.рф собирает в одном месте карточки препаратов, сравнительные таблицы, нормативные документы и инструменты расчёта рабочих растворов для медицины, пищевых производств, клининга и HoReCa.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/products/"
          class="rounded-full bg-sky-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-sky-200 transition hover:bg-sky-700"
        >
          Перейти в каталог
        </a>
        <a
          href="/tools/"
          class="rounded-full border border-sky-200 bg-white px-6 py-3 text-sm font-semibold text-sky-700 transition hover:border-sky-300 hover:bg-sky-50"
        >
          Открыть калькулятор
        </a>
      </div>
    </div>

    <aside class="section-shell grid gap-4 p-8">
      <div class="rounded-3xl bg-sky-600 p-6 text-white">
        <p class="text-sm uppercase tracking-[0.2em] text-sky-100">Фокус сайта</p>
        <p class="mt-4 text-3xl font-semibold">5 товарных карточек</p>
        <p class="mt-2 text-sm leading-6 text-sky-100">
          Стартовый каталог средств Химитек с краткой навигацией по областям применения.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-1">
        <div class="rounded-3xl border border-sky-100 bg-sky-50 p-5">
          <p class="text-sm font-semibold text-sky-800">Сравнение активных веществ</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Хлор, ЧАС, перекись и спирты в одном обзоре с практическими плюсами и ограничениями.
          </p>
        </div>
        <div class="rounded-3xl border border-sky-100 bg-white p-5">
          <p class="text-sm font-semibold text-slate-900">Нормативная база</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">
            Быстрый доступ к СанПиН, ГОСТ и методическим указаниям по дезинфекционным мероприятиям.
          </p>
        </div>
      </div>
    </aside>
  </section>

  <section class="mt-12">
    <div class="mb-6">
      <span class="eyebrow">Разделы сайта</span>
      <h2 class="section-title mt-4">Навигация по ключевым кластерам запросов</h2>
      <p class="section-copy mt-4 max-w-3xl">
        Каждая страница заточена под отдельный поисковый интент: выбор дезсредства, расчёт концентрации, сравнение химических групп, нормативные требования и обзор практики применения.
      </p>
    </div>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-5">
      {sections.map((section) => (
        <a href={section.href} class="section-shell group p-6 transition hover:-translate-y-1 hover:border-sky-200">
          <p class="text-sm font-semibold uppercase tracking-[0.18em] text-sky-700">Раздел</p>
          <h3 class="mt-4 text-xl font-semibold text-slate-900">{section.title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-600">{section.text}</p>
          <span class="mt-6 inline-flex text-sm font-semibold text-sky-700 transition group-hover:text-sky-900">
            Открыть →
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="section-shell mt-12 p-8 sm:p-10">
    <span class="eyebrow">О проекте</span>
    <h2 class="section-title mt-4">Дезинфекция без лишнего шума: от выбора состава до нормативного обоснования</h2>
    <div class="mt-6 grid gap-6 lg:grid-cols-3">
      <p class="section-copy">
        На сайте собраны базовые сведения по дезинфицирующим средствам для медицинских организаций, предприятий общественного питания, гостиниц, клининговых служб и пищевой промышленности. Акцент сделан на понятную структуру и быстрый поиск нужного режима обработки.
      </p>
      <p class="section-copy">
        В каталоге представлены стартовые карточки препаратов Химитек с указанием назначения, форм выпуска и сфер применения. Сравнительные материалы помогают выбрать между хлорсодержащими и бесхлорными средствами, а калькулятор разведения ускоряет подготовку рабочих растворов.
      </p>
      <p class="section-copy">
        Отдельный раздел с нормативными документами упрощает работу с требованиями СанПиН, ГОСТ и методических указаний. Такой формат полезен специалистам по инфекционному контролю, технологам, закупщикам и руководителям объектов с повышенными требованиями к санитарной безопасности.
      </p>
    </div>
  </section>
</Layout>
