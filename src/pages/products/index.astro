---
import Layout from "../../layouts/Layout.astro";

const products = [
  {
    name: "ПОЛИДЕЗ-СУПЕР",
    type: "Концентрат для комплексной дезинфекции",
    concentration: "0,1–2,0%",
    use: "Поверхности, санитарно-техническое оборудование, инвентарь, уборочный текстиль",
    features: ["Широкий спектр действия", "Подходит для текущей и генеральной уборки", "Удобен для рутинных режимов"]
  },
  {
    name: "УНИВЕРСАЛ-ДЕЗ",
    type: "Универсальное средство для объектов с высокой проходимостью",
    concentration: "0,25–1,5%",
    use: "ЛПУ, офисы, HoReCa, фитнес-центры, образовательные учреждения",
    features: ["Ориентировано на ежедневную обработку", "Применимо для разных типов покрытий", "Сбалансировано по моющей и дезинфицирующей активности"]
  },
  {
    name: "АНТИСЕПТИК-ГЕЛЬ",
    type: "Готовая кожная форма",
    concentration: "Готов к применению",
    use: "Гигиеническая обработка рук персонала, посетителей и пациентов",
    features: ["Быстрое нанесение", "Не требует разведения", "Удобен для дозаторов и постов гигиены"]
  },
  {
    name: "ДЕЗЭФФЕКТ",
    type: "Средство усиленного действия для сложных режимов",
    concentration: "0,2–3,0%",
    use: "Очаговая дезинфекция, технические зоны, оборудование и контейнеры",
    features: ["Подходит для усиленных режимов", "Рассчитан на профессиональное применение", "Уместен там, где важна высокая надёжность обработки"]
  },
  {
    name: "ПОЛИДЕЗ",
    type: "Базовый концентрат для объектов различного профиля",
    concentration: "0,1–1,0%",
    use: "Полы, стены, мебель, контактные поверхности, инвентарь",
    features: ["Рациональный выбор для регулярной дезинфекции", "Подходит для плановых санитарных мероприятий", "Простой в подготовке рабочих растворов"]
  }
];

const structuredData = {
  "@context": "https://schema.org",
  "@graph": products.map((product) => ({
    "@type": "Product",
    name: product.name,
    description: `${product.type}. Назначение: ${product.use}. Рабочая концентрация: ${product.concentration}.`,
    brand: {
      "@type": "Brand",
      name: "Химитек"
    },
    category: "Дезинфицирующее средство"
  }))
};
---

<Layout
  title="Каталог дезинфицирующих средств Химитек"
  description="Карточки дезинфицирующих средств Химитек: ПОЛИДЕЗ-СУПЕР, УНИВЕРСАЛ-ДЕЗ, АНТИСЕПТИК-ГЕЛЬ, ДЕЗЭФФЕКТ и ПОЛИДЕЗ."
  pathname="/products/"
  structuredData={structuredData}
>
  <section class="mb-8">
    <span class="eyebrow">Каталог средств</span>
    <h1 class="section-title mt-4">Дезсредства Химитек для медицинских, сервисных и производственных объектов</h1>
    <p class="section-copy mt-4 max-w-4xl">
      Ниже приведены стартовые карточки средств Химитек с краткими данными по назначению, диапазону рабочих концентраций и сценариям применения. Формат страницы подходит для быстрого сравнения препаратов перед закупкой или формированием схем санитарной обработки.
    </p>
  </section>

  <section class="grid gap-6 xl:grid-cols-2">
    {products.map((product) => (
      <article class="section-shell p-8" itemScope itemType="https://schema.org/Product">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-sky-700">Химитек</p>
            <h2 class="mt-3 text-2xl font-semibold text-slate-900" itemProp="name">{product.name}</h2>
          </div>
          <span class="rounded-full bg-sky-50 px-4 py-2 text-sm font-medium text-sky-800">
            {product.concentration}
          </span>
        </div>
        <p class="mt-5 text-base leading-7 text-slate-600" itemProp="description">{product.type}</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          <div class="rounded-3xl border border-sky-100 bg-sky-50 p-5">
            <p class="text-sm font-semibold text-sky-800">Рабочая концентрация</p>
            <p class="mt-2 text-sm leading-6 text-slate-700">{product.concentration}</p>
          </div>
          <div class="rounded-3xl border border-sky-100 bg-white p-5">
            <p class="text-sm font-semibold text-slate-900">Применение</p>
            <p class="mt-2 text-sm leading-6 text-slate-700">{product.use}</p>
          </div>
        </div>
        <ul class="mt-6 grid gap-3">
          {product.features.map((feature) => (
            <li class="rounded-2xl border border-slate-100 bg-slate-50 px-4 py-3 text-sm leading-6 text-slate-700">
              {feature}
            </li>
          ))}
        </ul>
      </article>
    ))}
  </section>
</Layout>
