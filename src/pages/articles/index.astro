---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { normalizeTag, sortArticlesByDate } from "../../lib/articles";

const articles = sortArticlesByDate(await getCollection("articles"));

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("ru-RU", {
    day: "numeric",
    month: "long",
    year: "numeric"
  }).format(date);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Статьи о дезинфекции",
  url: "https://дезинфицирующиесредства.рф/articles/",
  inLanguage: "ru"
};
---

<Layout
  title="Статьи о дезинфекции"
  description="Архив статей о дезинфекции: исследования, переводные дайджесты и практические обзоры."
  pathname="/articles/"
  structuredData={structuredData}
>
  <section class="section-shell p-8 sm:p-10">
    <span class="eyebrow">Архив</span>
    <h1 class="section-title mt-4">Статьи о дезинфекции</h1>
    <p class="section-copy mt-4 max-w-3xl">
      Все публикации блога, отсортированные по дате. Материалы оформлены как краткие русскоязычные дайджесты исследований и обзоры практики.
    </p>
  </section>

  <section class="mt-10 grid gap-6">
    {articles.map((article) => (
      <a href={`/articles/${article.id}/`} class="section-shell group p-6 sm:p-8 transition hover:-translate-y-1 hover:border-sky-200">
        <p class="text-sm font-medium text-sky-700">{formatDate(article.data.date)}</p>
        <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">{article.data.title}</h2>
        <p class="mt-4 max-w-3xl text-base leading-7 text-slate-600">{article.data.description}</p>
        <div class="mt-5 flex flex-wrap gap-2">
          {article.data.tags.map((tag) => {
            const normalizedTag = normalizeTag(tag);

            return (
              <a
                href={`/tags/${normalizedTag.slug}/`}
                class="rounded-full border border-sky-200 bg-sky-50 px-3 py-1 text-xs font-medium text-sky-700 transition hover:border-sky-300 hover:bg-sky-100"
              >
                #{normalizedTag.label}
              </a>
            );
          })}
        </div>
        <span class="mt-5 inline-flex text-sm font-semibold text-sky-700 transition group-hover:text-sky-900">
          Открыть материал →
        </span>
      </a>
    ))}
  </section>
</Layout>
