            <td class="border border-sky-100 px-3 py-2 text-center">✅</td>
            <td class="border border-sky-100 px-3 py-2 text-center">✅</td>
            <td class="border border-sky-100 px-3 py-2 text-center">⚠️</td>
            <td class="border border-sky-100 px-3 py-2 text-center">✅</td></tr>
          <tr><td class="border border-sky-100 px-3 py-2 font-medium">Микобактерии</td>
            <td class="border border-sky-100 px-3 py-2 text-center">⚠️</td>
            <td class="border border-sky-100 px-3 py-2 text-center">✅</td>
            <td class="border border-sky-100 px-3 py-2 text-center">✅</td>
            <td class="border border-sky-100 px-3 py-2 text-center">✅</td>
