            <th class="border border-sky-200 px-3 py-2 text-center">H₂O₂</th>
            <th class="border border-sky-200 px-3 py-2 text-center">Спирты</th>
            <th class="border border-sky-200 px-3 py-2 text-center">ПАА</th>
