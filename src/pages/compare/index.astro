---
import Layout from "../../layouts/Layout.astro";

const rows = [
  {
    type: "Хлорсодержащие",
    spectrum: "Очень широкий, включая вирусы и споры в усиленных режимах",
    pros: "Высокая эффективность, доступность, понятные схемы применения",
    cons: "Запах, возможная коррозия, требовательность к материалам",
    fit: "Очаговая дезинфекция, санитарные узлы, технические помещения"
  },
  {
    type: "ЧАС",
    spectrum: "Широкий, особенно для поверхностей и текущей профилактической обработки",
    pros: "Хорошая совместимость с покрытиями, моющий эффект, удобство рутинного применения",
    cons: "Не всегда оптимальны для тяжёлых загрязнений и отдельных устойчивых патогенов",
    fit: "Медицинские кабинеты, HoReCa, офисы, клининг"
  },
  {
    type: "Перекисные",
    spectrum: "Широкий, подходит для профессиональных режимов и объектов с высокими требованиями",
    pros: "Хорошая дезинфицирующая активность, менее выраженный запах, современный профиль применения",
    cons: "Более высокая стоимость и чувствительность к условиям хранения",
    fit: "ЛПУ, лаборатории, пищевые производства, чувствительные зоны"
  },
  {
    type: "Спиртовые",
    spectrum: "Быстрое действие против многих бактерий и вирусов на малых поверхностях и коже",
    pros: "Мгновенное высыхание, отсутствие смывания, удобство локальной обработки",
    cons: "Ограничено для больших площадей, пожароопасность, испаряемость",
    fit: "Антисептика рук, небольшие контактные поверхности, оборудование"
  }
];
---

<Layout
  title="Сравнение дезсредств: хлор, ЧАС, перекись и спирт"
  description="Сравнительная таблица групп дезинфицирующих средств: особенности, плюсы, ограничения и оптимальные зоны применения."
  pathname="/compare/"
>
  <section class="mb-8">
    <span class="eyebrow">Сравнение</span>
    <h1 class="section-title mt-4">Хлорные, ЧАС, перекисные и спиртовые средства: практическое сравнение</h1>
    <p class="section-copy mt-4 max-w-4xl">
      Ниже представлена базовая сравнительная таблица по основным группам действующих веществ. Она помогает быстро оценить, какая химическая группа лучше подходит для профилактической обработки, усиленных режимов, антисептики рук или работы с чувствительными поверхностями.
    </p>
  </section>

  <section class="section-shell overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full border-collapse text-left">
        <thead class="bg-sky-600 text-white">
          <tr>
            <th class="px-5 py-4 text-sm font-semibold">Группа</th>
            <th class="px-5 py-4 text-sm font-semibold">Спектр действия</th>
            <th class="px-5 py-4 text-sm font-semibold">Преимущества</th>
            <th class="px-5 py-4 text-sm font-semibold">Ограничения</th>
            <th class="px-5 py-4 text-sm font-semibold">Где применять</th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row, index) => (
            <tr class={index % 2 === 0 ? "bg-white" : "bg-sky-50/60"}>
              <td class="px-5 py-5 align-top text-sm font-semibold text-slate-900">{row.type}</td>
              <td class="px-5 py-5 align-top text-sm leading-6 text-slate-700">{row.spectrum}</td>
              <td class="px-5 py-5 align-top text-sm leading-6 text-slate-700">{row.pros}</td>
              <td class="px-5 py-5 align-top text-sm leading-6 text-slate-700">{row.cons}</td>
              <td class="px-5 py-5 align-top text-sm leading-6 text-slate-700">{row.fit}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>
</Layout>
