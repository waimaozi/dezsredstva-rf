---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  pathname?: string;
  image?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  pathname = "/",
  image = "/og-cover.jpg",
  ogType = "website",
  publishedTime,
  structuredData
} = Astro.props;

const siteUrl = "https://дезинфицирующиесредства.рф";
const canonical = new URL(pathname, siteUrl);
const ogImage = new URL(image, siteUrl);

const navItems = [
  { href: "/", label: "Главная" },
  { href: "/articles/", label: "Дайджесты" },
  { href: "/guides/", label: "Руководства" },
  { href: "/templates/", label: "Документы" },
  { href: "/tools/", label: "Калькулятор" },
  { href: "/about/", label: "О проекте" }
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content={ogType} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:site_name" content="Дезинфицирующиесредства.рф" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="alternate" type="application/rss+xml" title="Дезинфицирующиесредства.рф — RSS" href="/rss.xml" />
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}
    <!-- Yandex.Metrika counter -->
    <script is:inline>
      (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
      m[i].l=1*new Date();
      for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
      k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
      (window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
      ym(107711899, "init", {
        clickmap:true,
        trackLinks:true,
        accurateTrackBounce:true,
        webvisor:true
      });
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/107711899" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
  <meta name="yandex-verification" content="2b4a3951e876d12a" />
</head>
  <body class="bg-slate-50 text-slate-900 antialiased">
    <noscript><div><img src="https://mc.yandex.ru/watch/107711899" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <div class="medical-grid fixed inset-0 -z-10 opacity-60"></div>
    <header class="sticky top-0 z-40 border-b border-sky-100/80 bg-white/90 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
        <a href="/" class="flex items-center gap-3">
          <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-sky-600 text-lg font-semibold text-white shadow-lg shadow-sky-200">
            ДС
          </span>
          <span class="block text-lg font-semibold text-slate-900">
            Дезинфицирующиесредства.рф
          </span>
        </a>
        <nav aria-label="Основная навигация" class="hidden items-center gap-2 lg:flex">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-medium transition",
                pathname === item.href
                  ? "bg-sky-600 text-white shadow-lg shadow-sky-200"
                  : "text-slate-700 hover:bg-sky-50 hover:text-sky-700"
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
      <nav aria-label="Мобильная навигация" class="border-t border-sky-100 lg:hidden">
        <div class="mx-auto flex max-w-7xl gap-2 overflow-x-auto px-4 py-3 sm:px-6">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "whitespace-nowrap rounded-full px-3 py-2 text-sm font-medium transition",
                pathname === item.href
                  ? "bg-sky-600 text-white"
                  : "bg-white text-slate-700 ring-1 ring-sky-100 hover:bg-sky-50 hover:text-sky-700"
              ]}
            >
              {item.label}
            </a>
          ))}
        </div>
      </nav>
    </header>

    <main class="mx-auto min-h-[calc(100vh-12rem)] max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <slot />
    </main>

    <footer class="border-t border-sky-100 bg-white/90">
      <div class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-8 text-sm text-slate-600 sm:px-6 lg:px-8">
        <div>
          <p class="text-base font-semibold text-slate-900">Дезинфицирующиесредства.рф</p>
          <p class="mt-2 max-w-2xl">
            Блог о дезинфекции: переводы исследований, практические обзоры и полезные инструменты.
          </p>
        </div>
        <p>При поддержке <a href="https://chemitech.ru" target="_blank" rel="noreferrer" class="text-sky-700 transition hover:text-sky-900">chemitech.ru</a></p>
        <p class="text-xs text-slate-400 mt-2">v3.0 — 15.03.2026 17:57</p>
      </div>
    </footer>
  </body>
</html>
